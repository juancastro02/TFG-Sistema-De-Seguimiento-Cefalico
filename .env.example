VOICE_LENGTH_MS=1400
VOICE_KEEP_MS=100
VOICE_MAX_TOKENS=6
VOICE_FREQ_THRESHOLD=120
VOICE_VAD_THRESHOLD=0.75
VOICE_COMMAND_COOLDOWN_MS=1500
VOICE_COMMAND_REPEAT_WINDOW_MS=2800
VOICE_TRANSCRIPT_CONTEXT_MS=1800
VOICE_DUPLICATE_WINDOW_MS=1200
VOICE_REJECTED_WINDOW_MS=6000
